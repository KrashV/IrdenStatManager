{
  "gui": {
		"background": {
			"type" : "background",
			"fileHeader" : "/interface/scripted/irdenstatmanager/header.png",
      "fileBody" : "/interface/scripted/irdenstatmanager/body.png",
      "fileFooter" : "/interface/scripted/irdenstatmanager/footer.png"
		},
		"windowtitle" : {
			"type" : "title",
			"title" : "Irden Stat Manager",
			"subtitle" : "Вбей сюда всё то, что тебе лениво считать самому!",
			"position" : [0, 254],
			"icon" : {
			"type" : "image",
			"file" : "/interface/scripted/irdenstatmanager/staticons/locked.png",
			"position" : [0, 0],
			"zlevel" : -1
			}
		},

		"tooltipCanvas": {
			"type": "canvas",
			"rect": [0, 22, 383, 242],
			"captureMouseEvents": false,
			"captureKeyEvents": false,
			"mouseTransparent": true,
  		"zlevel": 99
		},

		"lblCharTab": {
			"type": "label",
			"hAnchor": "mid",
			"value": "Персонаж",
			"position": [45, 205]
		},
		
		"lblAttackTab": {
			"type": "label",
			"hAnchor": "mid",
			"value": "Действия",
			"position": [105, 205]
		},

		"lblWeaponTab": {
			"type": "label",
			"hAnchor": "mid",
			"value": "Снаряжение",
			"position": [165, 205]
		},
		
		"lblMiscTab": {
			"type": "label",
			"hAnchor": "mid",
			"value": "Бонусы",
			"position": [225, 205]
		},
		
		"rgTabs": {
			"type": "radioGroup",
			"position": [10, 200],
			"callback": "changeTab",
			"buttons": [
				{
					"selected": true,
					"baseImage": "/interface/scripted/irdenstatmanager/tabs/tabplayerbase.png",
					"hoverImage": "/interface/scripted/irdenstatmanager/tabs/tabplayerover.png",
					"baseImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabplayerselected.png",
					"hoverImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabplayerselectedover.png",
					"pressedOffset" : [0, 0],
					"position": [0, 0],
					"caption": "Характеристики",
					"data": "lytCharacter"
				},
				{
					"baseImage": "/interface/scripted/irdenstatmanager/tabs/tabactionsbase.png",
					"hoverImage": "/interface/scripted/irdenstatmanager/tabs/tabactionsover.png",
					"baseImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabactionsselected.png",
					"hoverImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabactionselectedover.png",
					"pressedOffset" : [0, 0],
					"position": [60, 0],
					"caption": "Действия",
					"data": "lytAttacks"
				},
				{
					"baseImage": "/interface/scripted/irdenstatmanager/tabs/tabgearbase.png",
					"hoverImage": "/interface/scripted/irdenstatmanager/tabs/tabgearover.png",
					"baseImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabgearselected.png",
					"hoverImageChecked": "/interface/scripted/irdenstatmanager/tabs/tabgearselectedover.png",
					"pressedOffset" : [0, 0],
					"position": [120, 0],
					"caption": "Снаряжение",
					"data": "lytArmory"
				},
				{
